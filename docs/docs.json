{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Cora",
  "description": "Safety-first community platform for Orange County residents. Built by locals, for locals.",
  "colors": {
    "primary": "#F27F0D",
    "light": "#FF9A35",
    "dark": "#DD7D00"
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "family": "Alexandria",
    "heading": {
      "family": "Gantari",
      "weight": 700
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "mailto:corafyi@gmail.com?subject=Cora"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Cora",
      "href": "https://cora.fyi"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "User guide",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "quickstart"]
          },
          {
            "group": "Account",
            "pages": [
              "account/sign-up",
              "account/phone-verification",
              "account/notifications"
            ]
          },
          {
            "group": "Reports",
            "pages": [
              "reports/browsing",
              "reports/submitting",
              "reports/voting-and-comments",
              "reports/flagging"
            ]
          },
          {
            "group": "Map",
            "pages": ["map/overview"]
          },
          {
            "group": "Help",
            "pages": ["help/faq", "help/troubleshooting"]
          }
        ]
      },
      {
        "tab": "Developers & docs site",
        "groups": [
          {
            "group": "Cora app & repo",
            "pages": ["development", "tech-stack"]
          },
          {
            "group": "Mintlify (this site)",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/navigation",
              "essentials/reusable-snippets",
              "essentials/settings"
            ]
          },
          {
            "group": "Editor tooling",
            "pages": ["ai-tools/cursor", "ai-tools/claude-code", "ai-tools/windsurf"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/Davidc45/Cora",
          "icon": "github",
          "color": {
            "light": "#111827",
            "dark": "#F27F0D"
          }
        },
        {
          "anchor": "Report an issue",
          "href": "mailto:corafyi@gmail.com?subject=Cora%20docs",
          "icon": "circle-exclamation",
          "color": {
            "light": "#F27F0D",
            "dark": "#FF9A35"
          }
        }
      ]
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Davidc45/Cora"
    }
  }
}
