{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Cora",
  "description": "Safety-first community platform for Orange County residents. Built by locals, for locals.",
  "colors": {
    "primary": "#F27F0D",
    "light": "#FF9A35",
    "dark": "#DD7D00"
  },
  "appearance": {
    "default": "light"
  },
  "fonts": {
    "family": "Alexandria",
    "heading": {
      "family": "Gantari",
      "weight": 700
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Contact",
        "href": "mailto:corafyi@gmail.com?subject=Cora"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Cora",
      "href": "https://cora.fyi"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "User Guide",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["user/introduction", "user/quickstart"]
          },
          {
            "group": "Submitting reports",
            "pages": [
              "user/how-to-report",
              "user/report-categories",
              "user/location-accuracy"
            ]
          },
          {
            "group": "Your account",
            "pages": ["user/creating-an-account", "user/privacy-and-data"]
          },
          {
            "group": "Support",
            "pages": ["user/faq"]
          }
        ]
      },
      {
        "tab": "Developer Docs",
        "groups": [
          {
            "group": "Overview",
            "pages": ["dev/introduction", "dev/tech-stack", "dev/architecture"]
          },
          {
            "group": "Setup",
            "pages": ["dev/environment-setup", "dev/environment-variables"]
          },
          {
            "group": "Database",
            "pages": ["dev/supabase-schema", "dev/postgis-setup"]
          },
          {
            "group": "Auth",
            "pages": ["dev/google-oauth", "dev/twilio-verify"]
          },
          {
            "group": "Deployment",
            "pages": ["dev/deployment-guide"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/Davidc45/Cora",
          "icon": "github",
          "color": {
            "light": "#111827",
            "dark": "#F27F0D"
          }
        },
        {
          "anchor": "Report an issue",
          "href": "mailto:corafyi@gmail.com?subject=Cora%20docs",
          "icon": "circle-exclamation",
          "color": {
            "light": "#F27F0D",
            "dark": "#FF9A35"
          }
        }
      ]
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Davidc45/Cora"
    }
  }
}
